.DS_Store
*.log
node_modules/
.vscode/
.idea/
.vercel
.env
.env.local
.env.prod
.env.*.local

# local-only thumbnail concept gallery
/thumbnails/
.env*.local

# Convex auto-generates types in this dir on every dev push -- regenerated
# from convex/schema.ts and convex/*.ts, not worth tracking.
convex/_generated/

# Local-only working folders for content drafts and prototypes.
/_drafts/
/_proto/

# Per-worktree artifacts
.claude/*.lock
.claude/*.bak
.claude/*.main-bak

# myphotos is a personal stash (typically a symlink), never tracked.
# No trailing slash so the rule catches both directories and symlinks.
/myphotos
.env.staging
node_modules

# i18n content-translation source chunks are derived from content.yaml by
# scripts/extract-i18n-source.mjs (regenerable). The de/fr overlays under
# i18n/content/<lang>/ and the built full/i18n/content.*.json ARE tracked.
/i18n/content/_source/
